---
import '@/styles/global.css'
import Header from '@/layouts/Header.astro'
import Footer from '@/components/Footer.astro'
import { Play } from '@/components/svg/index.astro'
import { Image } from 'astro:assets'
import logo from '/public/The_New_Order_Logo.png'
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/Astro-TNO//favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>TNO Cities Archive</title>
  </head>
  <body class="flex h-full flex-col">
    <Header />
    <main class="flex h-full flex-col items-center gap-8 overflow-y-auto p-4">
      <section class="flex flex-col gap-8">
        <header class="flex flex-col gap-4">
          <a
            href="https://steamcommunity.com/sharedfiles/filedetails/?id=2438003901"
            class="w-60 self-center md:w-80"
            target="_blank"
            aria-label="Steam"
          >
            <Image src={logo} alt="The New Order Logo" width={320} height={124.5} />
          </a>
          <div class="flex flex-row items-end gap-4">
            <h1
              class="inline text-2xl font-bold tracking-wider text-teal-500 text-shadow-[0_0_0.5rem] text-shadow-teal-400/80 md:text-4xl"
            >
              The New Order
            </h1><span class="inline text-lg text-mist-400 md:text-xl">Cities Archive</span>
          </div>
          <p class="self-end text-sm tracking-widest text-mist-500" aria-label="CLASSIFIED ARCHIVE · 1962">
            {
              'CLASSIFIED ARCHIVE · 1962'
                .split('')
                .map((char, i) => (
                  <span class={`inline-block ${i % 2 === 0 ? '-translate-y-px' : 'translate-y-px'}`}>
                    {char === ' ' ? '\u00A0' : char}
                  </span>
                ))
            }
          </p>
        </header>

        <article
          class="flex max-w-3xl flex-col gap-2 self-center border-y border-mist-800 py-6 indent-8 leading-relaxed text-mist-300"
        >
          <p>This is not a stable world.</p>
          <p>
            In <i>1962</i>, order still persists—but its foundations have already begun to fracture. <strong
              >Germanic Reich</strong
            >, <strong>Japan</strong> and <strong>USA</strong>maintain a fragile balance—one that is not peace, but
            merely a state that has yet to spiral out of control.
          </p>
          <p>
            Based on <a href="https://steamcommunity.com/sharedfiles/filedetails/?id=2438003901">mod version v1.9.0</a
            >￼, <a href="https://aaarynt.github.io/Astro-TNO/zh/">this site</a> documents key cities within
            <a href="https://steamcommunity.com/sharedfiles/filedetails/?id=2438003901">this universe</a>￼, from centers
            of power to distant colonial outposts. Each city serves as a reflection of collapsing order and the
            mechanisms of power that sustain it.
          </p>
        </article>

        <div class="flex flex-row items-center gap-8 pl-4">
          <a
            href={`${import.meta.env.BASE_URL}en/1/`}
            class="flex items-center gap-1 border border-mist-500 px-6 py-3 text-mist-200 transition hover:border-teal-500 hover:bg-mist-800/30"
          >
            <Play /><span class="translate-y-px">Enter Archives</span>
          </a>
          <a href={`${import.meta.env.BASE_URL}zh/About/`} class="text-mist-500 underline-offset-4 hover:underline">
            About This Mod
          </a>
        </div>

        <Footer
          arr={[
            { h4: 'TYPE', p: 'Worldview Archive' },
            { h4: 'SOURCE', p: 'TNO Mod Text' },
            { h4: 'STATUS', p: 'Unofficial Project' },
          ]}
        />
      </section>
    </main>
  </body>
</html>
