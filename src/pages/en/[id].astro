---
import '@/styles/global.css'
import en from '@/json/en.json'
import Layout from '@/layouts/Layout.astro'
import Nav from '@/components/Nav.astro'

export async function getStaticPaths() {
  return en.map((item) => ({
    params: {
      id: String(item.id),
    },
    props: {
      item,
    },
  }))
}

const { item } = Astro.props

type ParsedPart = { text: string; className?: string }

const COLOR_CLASS_BY_TAG = {
  R: 'text-red-400',
  Y: 'text-yellow-400',
} as const

const COLOR_TAG_RE = /§([RY])(.*?)§!/gi

function parseColorTags(text: string): ParsedPart[] {
  const parts: ParsedPart[] = []
  let cursor = 0

  for (const match of text.matchAll(COLOR_TAG_RE)) {
    const start = match.index ?? 0
    const full = match[0]
    const tag = match[1].toUpperCase() as keyof typeof COLOR_CLASS_BY_TAG
    const content = match[2]

    if (start > cursor) {
      parts.push({ text: text.slice(cursor, start) })
    }

    parts.push({ text: content, className: COLOR_CLASS_BY_TAG[tag] })
    cursor = start + full.length
  }

  if (cursor < text.length) {
    parts.push({ text: text.slice(cursor) })
  }

  return parts
}

const parsedParagraphs = item.desc.default.split('\n\n').map(parseColorTags)
---

<title>{item.name.default}</title>
<Layout>
  <section class="flex w-full max-w-3xl flex-col gap-6 overflow-y-auto px-4 pt-8 pb-10">
    <h2 class="text-3xl leading-tight font-bold text-mist-100 md:text-4xl">{item.name.default}</h2>
    <div class="aspect-413/70 w-full overflow-hidden bg-mist-800">
      <img
        src={`/Astro-TNO/img/state_lore_img_${item.id}.png`}
        class="h-full w-full object-cover"
        alt={item.name.default}
        width="640"
        height="108.5"
      />
    </div>
    <article class="prose prose-invert tno-prose max-w-none">
      {
        parsedParagraphs.map((parts) => (
          <p>{parts.map((part) => (part.className ? <span class={part.className}>{part.text}</span> : part.text))}</p>
        ))
      }
    </article>
    <Nav item={item} json={en} />
  </section>
</Layout>
