---
import { getRelativeLocaleUrl } from 'astro:i18n'
import zh from '@/json/zh.json'
import en from '@/json/en.json'
const lang = Astro.currentLocale ?? 'zh'
const data = lang === 'en' ? en : zh
const { id } = Astro.params
---

<aside
  data-aside-scroll
  class="fixed left-0 h-full w-[60%] -translate-x-full overflow-y-auto overscroll-contain border-r bg-black py-6 pl-4 text-lg transition-transform md:w-52 md:translate-0"
>
  <ul>
    {
      data.map((item) => (
        <li class:list={{ 'my-1 bg-teal-600 py-1 pl-2': id === item.id.toString() }}>
          <a
            href={getRelativeLocaleUrl(lang, `/${item.id}`)}
            aria-label={
              typeof item.name.default === 'string' && item.name.default.trim()
                ? item.name.default
                : `item-${item.initials}`
            }
            class:list={[
              'block',
              id === item.id.toString()
                ? 'text-xl text-black'
                : 'text-teal-500 text-shadow-teal-400/80 hover:text-shadow-[0_0_3px]',
            ]}
          >
            {item.name.default}
          </a>
        </li>
      ))
    }
  </ul>
</aside>

<script is:inline>
  ;(() => {
    const SELECTOR = '[data-aside-scroll]'
    const STORAGE_KEY = 'aside-scroll-top'
    const MANAGER_KEY = '__asideScrollManager'

    const getAside = () => document.querySelector(SELECTOR)
    const save = (el) => {
      if (!(el instanceof HTMLElement)) return
      sessionStorage.setItem(STORAGE_KEY, String(el.scrollTop))
    }
    const restore = (el) => {
      if (!(el instanceof HTMLElement)) return
      const saved = sessionStorage.getItem(STORAGE_KEY)
      if (saved === null) return
      const top = Number(saved)
      if (!Number.isFinite(top)) return
      requestAnimationFrame(() => {
        el.scrollTop = top
      })
    }

    if (!window[MANAGER_KEY]) {
      const manager = {
        aside: null,
        cleanup: null,
        bind() {
          if (typeof this.cleanup === 'function') this.cleanup()

          const el = getAside()
          this.aside = el instanceof HTMLElement ? el : null
          if (!this.aside) {
            this.cleanup = null
            return
          }

          const onScroll = () => save(this.aside)
          this.aside.addEventListener('scroll', onScroll, { passive: true })
          this.cleanup = () => this.aside?.removeEventListener('scroll', onScroll)
          restore(this.aside)
        },
      }

      document.addEventListener('astro:before-swap', () => save(manager.aside))
      document.addEventListener('astro:after-swap', () => manager.bind())
      window.addEventListener('beforeunload', () => save(manager.aside))
      window[MANAGER_KEY] = manager
    }

    window[MANAGER_KEY].bind()
  })()
</script>
