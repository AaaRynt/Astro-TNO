---
import { Github, Languages } from '@/components/svg/index.astro'
import { Image } from 'astro:assets'
import logo from '/public/TNOpediA_Logo.png'
const lang = Astro.url.pathname.match(/\/(zh|en)/)?.[1] ?? 'zh'
---

<header class="flex flex-row items-center justify-between gap-4 bg-teal-950 px-4 py-2">
  <div class="flex flex-row items-center gap-2">
    <a href=`/Astro-TNO/${lang}/` class="hover:underline">HOME</a>
    <span class="text-teal-400">/</span>
    <a href="https://github.com/AaaRynt/Astro-TNO" target="_blank" aria-label="GitHub">
      <Github />
    </a>
  </div>
  <!-- <input type="text" class="rounded-sm outline-1" /> -->
  <div class="flex flex-row items-center gap-2">
    <Languages />
    <select name="lang">
      <option value="zh">简体中文</option>
      <option value="en">English</option>
    </select>
    <a href="https://tno.wiki/wiki/TNOpediA" target="_blank" aria-label="TNOpediA">
      <Image src={logo} alt="The New Order Logo" class={'size-8'} width={32} height={32} />
    </a>
  </div>
</header>

<script is:inline>
  const fullPath = window.location.pathname,
    select = document.querySelector('select')
  let path = fullPath.replace(/^\/Astro-TNO/, '').replace(/^\/(zh|en)/, '')
  if (!path.startsWith('/')) path = '/' + path
  select.value = fullPath.match(/^\/Astro-TNO\/(zh|en)/)?.[1] || 'zh'
  select.addEventListener('change', (e) => {
    window.location.href = `/Astro-TNO/${e.target.value}${path}`
  })
</script>
