---
interface Props {
  arr: { h4: string; p: string }[]
}
const { arr } = Astro.props
---

<footer
  class="grid w-full gap-4 border-t border-mist-800 pt-4 text-sm text-mist-400"
  style={`grid-template-columns: repeat(${arr.length}, minmax(0, 1fr));`}
>
  {
    arr.map((item) => (
      <div class="border border-mist-800 px-4 py-2">
        <h4 class="text-mist-500">{item.h4}</h4>
        <p>{item.p}</p>
      </div>
    ))
  }
</footer>
